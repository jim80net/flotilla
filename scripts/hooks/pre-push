#!/usr/bin/env bash
# pre-push — local backstop before push leaves this clone.
#
# 1. Go hygiene (mirrors CI): gofmt -l . + go vet ./... — blocks on any unformatted file.
# 2. Public/private partition: scans ADDED lines in the push range through
#    scripts/check-private-boundary.sh --file.
#
# BACKSTOP only — `--no-verify` bypasses this; CI is the enforcing gate of record.
#
# Install:  git config core.hooksPath scripts/hooks
#           (or: scripts/install-hooks.sh)
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

unformatted="$(gofmt -l .)"
if [ -n "$unformatted" ]; then
  echo "pre-push: gofmt would fail CI on:" >&2
  echo "$unformatted" >&2
  echo "Run: gofmt -w ." >&2
  exit 1
fi
go vet ./...
guard="$repo_root/scripts/check-private-boundary.sh"
[ -x "$guard" ] || guard="bash $repo_root/scripts/check-private-boundary.sh"

z40="0000000000000000000000000000000000000000"
# The empty-tree object — a stable base for diffing a brand-new branch's whole history
# (so we never fall back to a single-arg `git diff <sha>`, which compares the WORKING
# TREE against <sha> and would silently miss leaks that are actually in the commits).
empty_tree="$(git hash-object -t tree /dev/null)"
tmp="$(mktemp)"
trap 'rm -f "$tmp"' EXIT

# A pre-push hook receives "<local_ref> <local_sha> <remote_ref> <remote_sha>" lines on
# stdin, one per ref being pushed. Collect the ADDED lines across every pushed range.
had_range=0
while read -r _local_ref local_sha _remote_ref remote_sha; do
  [ "$local_sha" = "$z40" ] && continue # a branch deletion has nothing to scan
  if [ "$remote_sha" != "$z40" ]; then
    base="$remote_sha"
  else
    # New branch on the remote: diff from its merge-base with the default branch (the
    # commits this push introduces); if origin/main is unknown, fall back to the empty
    # tree so the WHOLE branch's added lines are scanned (always a two-endpoint diff).
    base="$(git merge-base origin/main "$local_sha" 2>/dev/null || true)"
    [ -n "$base" ] || base="$empty_tree"
  fi
  # The added lines (drop the +++ file-header lines; keep the leading + — the leak
  # patterns match substrings, so it is harmless and avoids a second pipe).
  git diff "$base..$local_sha" -- . | grep '^+' | grep -v '^+++' >> "$tmp" || true
  had_range=1
done

if [ "$had_range" -eq 0 ] || [ ! -s "$tmp" ]; then
  exit 0 # nothing added to scan (e.g. a deletion-only or empty push)
fi

# Fail-closed: the guard exits 1 on a denylist/generic hit (blocks the push) and 0 on
# clean-or-advisory-warn-only (the WARN section prints but does not block).
$guard --file "$tmp"
