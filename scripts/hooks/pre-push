#!/usr/bin/env bash
# pre-push — the LOCAL fail-closed backstop of the public/private partition.
#
# It scans the ADDED lines of the commits being pushed (the push RANGE, not the whole
# tree) through scripts/check-private-boundary.sh --file, so a deployment specific that
# reached a commit is caught before it leaves your machine. This is a BACKSTOP, not the
# authority: a local hook is `--no-verify`-bypassable, so CI's `private-boundary` job is
# the enforcing gate of record. The advisory WARN tier (domain vocabulary) prints but
# never blocks (exit 0); a fail-closed denylist/generic hit blocks the push (exit 1).
#
# Install:  git config core.hooksPath scripts/hooks
#           (or: scripts/install-hooks.sh)
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
guard="$repo_root/scripts/check-private-boundary.sh"
[ -x "$guard" ] || guard="bash $repo_root/scripts/check-private-boundary.sh"

z40="0000000000000000000000000000000000000000"
tmp="$(mktemp)"
trap 'rm -f "$tmp"' EXIT

# A pre-push hook receives "<local_ref> <local_sha> <remote_ref> <remote_sha>" lines on
# stdin, one per ref being pushed. Collect the ADDED lines across every pushed range.
had_range=0
while read -r _local_ref local_sha _remote_ref remote_sha; do
  [ "$local_sha" = "$z40" ] && continue # a branch deletion has nothing to scan
  if [ "$remote_sha" = "$z40" ]; then
    # New branch on the remote: scan from its merge-base with the default branch (the
    # commits this push actually introduces), falling back to the whole branch.
    base="$(git merge-base origin/main "$local_sha" 2>/dev/null || true)"
  else
    base="$remote_sha"
  fi
  if [ -n "$base" ]; then
    range="$base..$local_sha"
  else
    range="$local_sha"
  fi
  # The added lines (drop the +++ file-header lines; keep the leading + — the leak
  # patterns match substrings, so it is harmless and avoids a second pipe).
  git diff "$range" -- . | grep '^+' | grep -v '^+++' >> "$tmp" || true
  had_range=1
done

if [ "$had_range" -eq 0 ] || [ ! -s "$tmp" ]; then
  exit 0 # nothing added to scan (e.g. a deletion-only or empty push)
fi

# Fail-closed: the guard exits 1 on a denylist/generic hit (blocks the push) and 0 on
# clean-or-advisory-warn-only (the WARN section prints but does not block).
$guard --file "$tmp"
