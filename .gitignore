# Secrets — never commit credentials or generated webhook files
*.env
.env
.env.*
secrets/
*-webhooks.env

# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/

# Tooling
.mypy_cache/
.ruff_cache/
.pytest_cache/
.coverage
htmlcov/

# Editor / OS
.DS_Store
*.swp
.idea/
.vscode/

# Claude Code agent worktrees (transient, per-subagent git worktrees; auto-cleaned).
# Never commit them — they are isolated checkouts, not project content.
.claude/worktrees/

# Session-continuity handoffs (internal working memory; saturated with host/operator
# context — kept on disk, never committed).
.claude/handoffs/

# flotilla-owned handoff/switch artifacts (deployment-specific; never committed — #218).
.flotilla/handoffs/
.flotilla/switch/

# Live roster (secret-free by design, but holds your real ids — keep the example committed)
/flotilla.json

# Real fleet goals (your deployment's actual goal hierarchy + its compiled JSON —
# host-local, holds real desk/aim names). The .example.{yaml,json} templates ARE
# committed as the public reference; your filled-in copies are not (#301).
/fleet-goals.yaml
/fleet-goals.json

# Host-local launch recipes (holds this host's worktree paths — never commit the
# filesystem layout; trusted at the secrets level, sibling of flotilla-secrets.env)
/flotilla-launch.json

# Your deployment's private denylist for the boundary guard (your real desk/org/
# broker names). The .example template IS committed; your filled-in copy is not.
/.flotilla/private-denylist

# Your deployment's private WARNLIST — the advisory domain-vocabulary tier (your
# trading/medical/legal/etc. jargon). A warnlist hit is ADVISORY (warn + publish /
# CI exit 0), never a hard block. The .example template IS committed; your filled-in
# copy is not — the vocabulary itself is circumstantial and must never reach the
# public tree.
/.flotilla/private-warnlist

# flotilla-watch host paths: the per-host deploy/flotilla-watch.env is already
# ignored by *.env above (desired — per-host layout). The test fixture also ends in
# .env, so *.env would catch it — re-include it explicitly so CI can see it. (The
# .env.example is NOT matched by *.env, but listed here for clarity.)
!/deploy/flotilla-watch.env.example
!/deploy/testdata/flotilla-watch.fixture.env
# Same re-include for the voice deploy: the .example files are not *.env-matched, but the
# test fixture ends in .env and CI's install-test needs it committed.
!/deploy/testdata/flotilla-voice.fixture.env
# Same re-include for the doctor deploy: the per-host deploy/flotilla-doctor.env is
# *.env-ignored (desired), but the install-test fixture ends in .env and CI needs it.
!/deploy/testdata/flotilla-doctor.fixture.env
# Same re-include for the dash deploy: the per-host deploy/flotilla-dash.env is
# *.env-ignored (desired), but the install-test fixture ends in .env and CI needs it.
!/deploy/testdata/flotilla-dash.fixture.env

# Desk-local scratch notes (per-desk working memory; never committed).
.claude/desk-state/

# PR-body working files (docs/pr-authoring.md composes descriptions here and delivers
# them via --body-file / REST; local drafts, never committed).
.claude/pr-bodies/

# Authority-domain materialization (`flotilla workspace init` / `resume` writes
# .gatekeeper/domain and related files into each worktree — runtime desk state,
# never committed; see openspec/changes/authority-domains-org-chart/).
/.gatekeeper/
