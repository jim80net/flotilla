# Secrets — never commit credentials or generated webhook files
*.env
.env
.env.*
secrets/
*-webhooks.env

# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/

# Tooling
.mypy_cache/
.ruff_cache/
.pytest_cache/
.coverage
htmlcov/

# Editor / OS
.DS_Store
*.swp
.idea/
.vscode/

# Live roster (secret-free by design, but holds your real ids — keep the example committed)
/flotilla.json

# Host-local launch recipes (holds this host's worktree paths — never commit the
# filesystem layout; trusted at the secrets level, sibling of flotilla-secrets.env)
/flotilla-launch.json
