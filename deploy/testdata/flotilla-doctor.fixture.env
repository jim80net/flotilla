# Host-neutral fixture for the installer regression test
# (cmd/flotilla/doctor_install_test.go). Mirrors a real deployment's SHAPE — every
# placeholder key present — without baking any real host's paths into the repo.
FLOTILLA_DOCTOR_DEST=%h/.local/bin/flotilla-doctor
FLOTILLA_SELF=hydra-ops
FLOTILLA_SECRETS=/srv/fleet/secrets.env
FLOTILLA_WORKDIR=/srv/fleet
FLOTILLA_BIN=%h/go/bin/flotilla
FLOTILLA_CLAUDE_BIN=/usr/local/bin/claude
FLOTILLA_RECOVER_SKILL=recover-flotilla
FLOTILLA_DOCTOR_STATE_DIR=/srv/fleet/state
