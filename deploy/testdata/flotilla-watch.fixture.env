# Host-neutral fixture for the installer regression test
# (cmd/flotilla/watch_install_test.go). Mirrors a real deployment's SHAPE — every
# flag present, in order — without baking any real host's paths into the repo.
FLOTILLA_WORKDIR=/srv/fleet
FLOTILLA_BIN=%h/go/bin/flotilla
FLOTILLA_ROSTER=/srv/fleet/flotilla.json
FLOTILLA_SECRETS=/srv/fleet/secrets.env
FLOTILLA_ACK_FILE=/srv/fleet/xo-alive
