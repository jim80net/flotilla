# Host-neutral fixture for the installer regression test
# (cmd/flotilla/dash_install_test.go). Mirrors a real deployment's SHAPE — every flag
# present, in order, INCLUDING the optional --repo + --secrets — without baking any
# real host's paths into the repo.
FLOTILLA_DASH_WORKDIR=/srv/fleet
FLOTILLA_DASH_BIN=%h/go/bin/flotilla
FLOTILLA_DASH_ROSTER=/srv/fleet/flotilla.json
FLOTILLA_DASH_BIND=127.0.0.1:8787
FLOTILLA_DASH_REPO=owner/name
FLOTILLA_DASH_SECRETS=/srv/fleet/secrets.env
FLOTILLA_DASH_BACKLOG_FILE=/srv/fleet/fleet-backlog.md
