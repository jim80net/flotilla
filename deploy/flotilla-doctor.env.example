# flotilla-doctor host paths — consumed by deploy/flotilla-doctor-install.sh to
# generate ~/.config/systemd/user/flotilla-doctor.service from
# deploy/flotilla-doctor.service.in, and to copy the escalator script + timer.
#
# SETUP (one-time per host):
#   cp deploy/flotilla-doctor.env.example deploy/flotilla-doctor.env
#   $EDITOR deploy/flotilla-doctor.env       # set the paths for THIS host
#   bash deploy/flotilla-doctor-install.sh   # generate + install unit/script/timer
#   systemctl --user enable --now flotilla-doctor.timer
#
# deploy/flotilla-doctor.env is gitignored: these are filesystem paths (NOT secrets),
# but the layout is per-host, so each host keeps its own. To change paths later, edit
# this file and re-run the installer — never hand-edit the installed unit.
#
# Paths may use the systemd specifier %h (your home directory) IN THE UNIT'S
# WorkingDirectory only; the doctor script's ExecStart flags are passed to a bash
# script that runs `"$BIN"` / `"$CLAUDE"` directly, so a LITERAL absolute path is
# safer there than %h (bash does not expand %h). The example below uses literal paths.
# Values are taken LITERALLY — do NOT quote them; whitespace around `=` is trimmed.

# ---- required (these become @PLACEHOLDER@ substitutions in the unit) ----

# Where the installer COPIES deploy/flotilla-doctor.sh (the escalator) and what the
# unit's ExecStart runs. A stable per-user path.
FLOTILLA_DOCTOR_DEST=/home/jim/.local/bin/flotilla-doctor

# The `--from` identity for the operator notify (a webhook name in the secrets file).
FLOTILLA_SELF=hydra-ops

# Secrets file (chmod 600) holding FLOTILLA_WEBHOOK_<SELF> for the notify post.
FLOTILLA_SECRETS=/home/jim/workspace/github.com/General-ML/spark/state/flotilla-secrets.env

# Working directory for the doctor run AND the cwd the recovery agent runs in (so the
# recover-flotilla skill's `flotilla notify --secrets state/...` resolves). The spark
# repo root, where state/flotilla*.{json,env} live.
FLOTILLA_WORKDIR=/home/jim/workspace/github.com/General-ML/spark

# The flotilla binary (used for the best-effort operator notify on escalation).
FLOTILLA_BIN=/home/jim/go/bin/flotilla

# The claude binary the escalator spawns headless: `claude --print "/<skill> …"`.
FLOTILLA_CLAUDE_BIN=/home/jim/.local/bin/claude

# The recovery skill name the escalator invokes (`/<skill> <status>`).
FLOTILLA_RECOVER_SKILL=recover-flotilla

# State dir for the doctor's lock/strike/cooldown files + its log. The spark state dir
# is a natural home (the same place flotilla's ack file and roster live).
FLOTILLA_DOCTOR_STATE_DIR=/home/jim/workspace/github.com/General-ML/spark/state

# ---- optional tunables (defaults shown; the script also defaults these) ----
# Confirmed-down strikes before escalating (cadence 3min × 3 ≈ ~9 min confirmed).
# FLOTILLA_DOCTOR_THRESHOLD=3
# Seconds to suppress re-spawning the recovery agent after an escalation.
# FLOTILLA_DOCTOR_COOLDOWN=1800
# Seconds to wait before the single confirm-recheck after the first down read.
# FLOTILLA_DOCTOR_RECHECK=15
