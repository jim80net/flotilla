# flotilla-voice host paths — consumed by deploy/flotilla-voice-install.sh to generate
# ~/.config/systemd/user/flotilla-voice.service from deploy/flotilla-voice.service.in.
#
# SETUP (one-time per host):
#   cp deploy/flotilla-voice.env.example deploy/flotilla-voice.env
#   $EDITOR deploy/flotilla-voice.env        # set the five paths for THIS host
#   bash deploy/flotilla-voice-install.sh    # generate + install the unit
#
# deploy/flotilla-voice.env is gitignored: these are filesystem paths (NOT secrets), but the
# layout is per-host. To change paths later, edit this file and re-run the installer — never
# hand-edit the installed unit.
#
# Paths may use the systemd specifier %h (your home directory): the installer passes it
# through literally and systemd resolves it at runtime. Absolute paths also work. Values are
# taken LITERALLY — do NOT quote them; whitespace around the `=` is trimmed.
#
# NOTE: the binary at FLOTILLA_BIN MUST be built with `-tags voiceopus` (CGO + libopus-dev).
# A core CGO_ENABLED=0 binary will start and immediately exit with a clear rebuild message.

# Working directory for the daemon. `flotilla voice` defaults --config to state/voice.env
# RELATIVE to this dir, so set it to your repo/state root (or give FLOTILLA_VOICE_CONFIG an
# absolute path below).
FLOTILLA_WORKDIR=%h

# The voice-enabled flotilla binary (built with -tags voiceopus). Example install:
#   CGO_ENABLED=1 go build -tags voiceopus -o %h/go/bin/flotilla-voice ./cmd/flotilla
FLOTILLA_BIN=%h/go/bin/flotilla-voice

# The voice runtime config (XAI key + channel/operator/cap). Copy it from
# deploy/voice.env.example, fill it in, and chmod 600 — it holds the XAI_API_KEY secret.
FLOTILLA_VOICE_CONFIG=%h/.config/flotilla/voice.env

# Roster (committable, no secrets): must contain the VOICE_XO_AGENT named in voice.env.
FLOTILLA_ROSTER=%h/.config/flotilla/flotilla.json

# Secrets (chmod 600, never committed): FLOTILLA_BOT_TOKEN — the voice process reuses the
# same Discord bot token as the relay to open its own voice-intent gateway session.
FLOTILLA_SECRETS=%h/.config/flotilla/flotilla-secrets.env
