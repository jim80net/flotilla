# flotilla voice RUNTIME config — consumed by `flotilla voice --config <this file>`
# (loaded by loadVoiceConfig). This is a SECRET file: it holds XAI_API_KEY.
#
# SETUP:
#   cp deploy/voice.env.example ~/.config/flotilla/voice.env   # (or wherever FLOTILLA_VOICE_CONFIG points)
#   $EDITOR ~/.config/flotilla/voice.env                       # fill in the real values
#   chmod 600 ~/.config/flotilla/voice.env                     # never world-readable, never committed
#
# It is gitignored by the `*.env` rule. KEY=VALUE; `export ` prefixes, surrounding quotes,
# blank lines, and `#` comments are tolerated; whitespace around `=` is trimmed.

# Grok (xAI) API key for STT + TTS. Copy it from your provider's key file (e.g.
# ~/.config/<provider>/.env), decoupling voice from any one agent's config. NEVER
# commit this file or print this value.
XAI_API_KEY=xai-REPLACE-WITH-YOUR-KEY

# The Discord guild (server) and the VOICE channel to join. Right-click the server/channel
# with Developer Mode on → Copy ID.
VOICE_GUILD_ID=000000000000000000
VOICE_CHANNEL_ID=000000000000000000

# The operator's Discord user id — the ONLY speaker whose audio is transcribed and injected
# (fail-closed: every other / unattributed speaker is dropped). Copy ID from your user.
VOICE_OPERATOR_USER_ID=000000000000000000

# The roster agent whose tmux pane receives voice transcripts (the XO). Must exist in the
# roster passed via --roster.
VOICE_XO_AGENT=xo

# Session spend cap in USD (a positive number). Grok pricing: STT $0.10/hr, TTS $4.20/1M
# chars — a real push-to-talk session is cents; this is the hard stop. On the cap the
# session goes quiet (no more STT/TTS) until the process is restarted.
VOICE_COST_CAP_USD=2.50
