{
  "tiers": {
    "read_unprompted": {
      "description": "Safe reads unprompted. Explicit read-only git subcommands with git -C/--git-dir prefix variants.",
      "allow": [
        "Bash(gh pr list*)",
        "Bash(gh pr view*)",
        "Bash(gh pr checks*)",
        "Bash(gh pr diff*)",
        "Bash(gh issue list*)",
        "Bash(gh issue view*)",
        "Bash(gh run list*)",
        "Bash(gh run view*)",
        "Bash(echo*)",
        "Bash(ls*)",
        "Bash(cat*)",
        "Bash(head*)",
        "Bash(tail*)",
        "Bash(grep*)",
        "Bash(rg*)",
        "Bash(find*)",
        "Bash(wc*)",
        "Bash(which*)",
        "Bash(stat*)",
        "Bash(file*)",
        "Bash(tree*)",
        "Bash(pwd*)",
        "Bash(date*)",
        "Bash(curl -sI*)",
        "Bash(dig*)",
        "Bash(nslookup*)",
        "Bash(whois*)",
        "Bash(host *)",
        "Bash(pytest*)",
        "Bash(python -m pytest*)",
        "Bash(python3 -m pytest*)",
        "Bash(uv run pytest*)",
        "Bash(.venv/bin/python -m pytest*)",
        "Bash(mypy*)",
        "Bash(python -m mypy*)",
        "Bash(python3 -m mypy*)",
        "Bash(uv run mypy*)",
        "Bash(.venv/bin/python -m mypy*)",
        "Bash(go test*)",
        "Bash(go build*)",
        "Bash(go vet*)",
        "Bash(gofmt -l*)",
        "Bash(codex --help*)",
        "Bash(codex --version*)",
        "Bash(codex help*)",
        "Bash(codex login status*)",
        "Bash(codex doctor*)",
        "Bash(codex features*)",
        "Bash(codex plugin --help*)",
        "Bash(codex debug --help*)",
        "Bash(flotilla --help*)",
        "Bash(flotilla status*)",
        "Bash(flotilla result*)",
        "Bash(touch */flotilla-*-settled)",
        "Bash(touch */flotilla-*-alive)",
        "Bash(git show*)",
        "Bash(git * show*)",
        "Bash(git log*)",
        "Bash(git * log*)",
        "Bash(git diff*)",
        "Bash(git * diff*)",
        "Bash(git status*)",
        "Bash(git * status*)",
        "Bash(git rev-parse*)",
        "Bash(git * rev-parse*)",
        "Bash(git describe*)",
        "Bash(git * describe*)",
        "Bash(git blame*)",
        "Bash(git * blame*)",
        "Bash(git grep*)",
        "Bash(git * grep*)",
        "Bash(git ls-files*)",
        "Bash(git * ls-files*)",
        "Bash(git ls-tree*)",
        "Bash(git * ls-tree*)",
        "Bash(git cat-file*)",
        "Bash(git * cat-file*)",
        "Bash(git shortlog*)",
        "Bash(git * shortlog*)",
        "Bash(git branch -v*)",
        "Bash(git * branch -v*)",
        "Bash(git branch -vv*)",
        "Bash(git * branch -vv*)",
        "Bash(git branch -a*)",
        "Bash(git * branch -a*)",
        "Bash(git branch -r*)",
        "Bash(git * branch -r*)",
        "Bash(git branch --list*)",
        "Bash(git * branch --list*)",
        "Bash(git branch -l*)",
        "Bash(git * branch -l*)",
        "Bash(git remote -v*)",
        "Bash(git * remote -v*)",
        "Bash(git remote show*)",
        "Bash(git * remote show*)",
        "Bash(git config --get*)",
        "Bash(git * config --get*)",
        "Bash(git config --list*)",
        "Bash(git * config --list*)",
        "Bash(git config -l*)",
        "Bash(git * config -l*)",
        "Bash(git stash list*)",
        "Bash(git * stash list*)"
      ]
    },
    "never_autonomous": {
      "description": "Hard deny irreversible/coordinator-only ops incl. force push (+refspec), main/master push, and :refspec branch deletion.",
      "deny": [
        "Bash(gh pr merge*)",
        "Bash(git push --force*)",
        "Bash(git * push --force*)",
        "Bash(git push -f *)",
        "Bash(git * push -f *)",
        "Bash(git push * --force*)",
        "Bash(git * push * --force*)",
        "Bash(git push --force-with-lease*)",
        "Bash(git * push --force-with-lease*)",
        "Bash(git push *+*)",
        "Bash(git * push *+*)",
        "Bash(git push +*)",
        "Bash(git * push +*)",
        "Bash(git push origin main*)",
        "Bash(git * push origin main*)",
        "Bash(git push origin master*)",
        "Bash(git * push origin master*)",
        "Bash(git push * main*)",
        "Bash(git * push * main*)",
        "Bash(git push * master*)",
        "Bash(git * push * master*)",
        "Bash(git push origin refs/heads/main*)",
        "Bash(git * push origin refs/heads/main*)",
        "Bash(git push origin refs/heads/master*)",
        "Bash(git * push origin refs/heads/master*)",
        "Bash(git push * refs/heads/main*)",
        "Bash(git * push * refs/heads/main*)",
        "Bash(git push * refs/heads/master*)",
        "Bash(git * push * refs/heads/master*)",
        "Bash(git push origin :main*)",
        "Bash(git * push origin :main*)",
        "Bash(git push origin :master*)",
        "Bash(git * push origin :master*)",
        "Bash(git push * :main*)",
        "Bash(git * push * :main*)",
        "Bash(git push * :master*)",
        "Bash(git * push * :master*)",
        "Bash(git push origin :refs/heads/main*)",
        "Bash(git * push origin :refs/heads/main*)",
        "Bash(git push origin :refs/heads/master*)",
        "Bash(git * push origin :refs/heads/master*)",
        "Bash(git push * :refs/heads/main*)",
        "Bash(git * push * :refs/heads/main*)",
        "Bash(git push * :refs/heads/master*)",
        "Bash(git * push * :refs/heads/master*)",
        "Bash(git reset --hard*)",
        "Bash(git * reset --hard*)",
        "Bash(git rebase*)",
        "Bash(git * rebase*)",
        "Bash(git clean*)",
        "Bash(git * clean*)"
      ]
    }
  }
}

