{
  "_comment": "Canonical fleet role permission policy (public-safe prototype). Compiler emits gatekeeper TOML overlays + harness-native materializations. schema_version bump triggers bootstrap permissions sync.",
  "schema_version": 1,
  "policy": {
    "on_gatekeeper_error": "abstain",
    "design_criteria": "zero_approval_noise_for_role_authorized_ops",
    "description": "Autonomous fleet steady state: role-authorized flows (communication, state R/W, inspect, dispatch, gate, merge, deploy, reap) proceed without per-command harness approvals. Safety from role boundaries, no self-merge, lane scoping, audit logs, reversible ops, and operator gates for money/irreversible/fork — not per-command prompting. Gatekeeper errors defer to native; deny spine still applies on matched rules."
  },
  "roles": {
    "cos": {
      "extends": "xo",
      "capabilities": ["flotilla.notify", "flotilla.send", "flotilla.status", "fleet.state.rw", "gh.merge", "tmux.inspect", "detector.ack"]
    },
    "meta-xo": {
      "extends": "xo",
      "capabilities": ["fleet.command"],
      "_comment": "Fleet command coordinator (xo_agent clock). Same permission tier as xo."
    },
    "ops-xo": {
      "extends": "xo",
      "capabilities": [
        "fleet.ops",
        "bootstrap.doctor",
        "permissions.sync",
        "rename.plan",
        "roster.hygiene"
      ],
      "bash_allow": [
        "flotilla bootstrap*",
        "scripts/bootstrap-*",
        "scripts/compile-flotilla-permissions*",
        "scripts/check-private-boundary*"
      ],
      "_comment": "Fleet operations accountability — NOT product implementation. Default assignee for bootstrap/permissions/rename."
    },
    "xo": {
      "_comment": "Product/project XO — implementation lanes only; not fleet-ops owner",
      "capabilities": [
        "flotilla.notify",
        "flotilla.send",
        "flotilla.status",
        "flotilla.register",
        "flotilla.recycle",
        "fleet.state.rw",
        "gh.merge",
        "gh.review",
        "gh.read",
        "git.read",
        "deploy.build",
        "tmux.inspect",
        "detector.ack"
      ],
      "bash_allow": [
        "flotilla status*",
        "flotilla send*",
        "flotilla notify*",
        "flotilla register*",
        "flotilla recycle*",
        "flotilla result*",
        "touch *flotilla-*-alive*",
        "touch *flotilla-*-settled*",
        "gh pr merge*",
        "gh pr view*",
        "gh pr diff*",
        "gh pr checks*",
        "gh pr review*",
        "gh pr list*",
        "git status*",
        "git diff*",
        "git log*",
        "git show*",
        "go test*",
        "go build*",
        "make test*",
        "tmux list-panes*",
        "tmux capture-pane*"
      ],
      "bash_deny": [
        "git push origin main*",
        "git push origin master*",
        "git push *+refspec*",
        "git push --force*",
        "git reset --hard*"
      ]
    },
    "adjutant": {
      "capabilities": [
        "flotilla.status",
        "fleet.state.r",
        "buffer.rw",
        "tmux.inspect",
        "laminar.seam_inject",
        "laminar.no_interject_during_operator_window"
      ],
      "urgent_bypass_classes": [
        "money",
        "irreversible",
        "divergent_fork",
        "incident_safety",
        "officer_incapacitation",
        "usage_limit",
        "operator_relay"
      ],
      "_comment_laminar": "Behavioral contract in bootstrap §2.4 — permissions allow buffer/charter paths; seam policy enforced by watch adjutant buffer",
      "bash_allow": [
        "flotilla status*",
        "cat *flotilla-*-buffer.json*",
        "cat *-adjutant-charter.md*",
        "git status*",
        "git diff*",
        "git log*"
      ],
      "bash_deny": [
        "flotilla notify*",
        "gh pr merge*",
        "git push origin main*",
        "git push --force*"
      ]
    },
    "desk": {
      "capabilities": [
        "flotilla.status",
        "lane.worktree.rw",
        "git.feature",
        "test.run"
      ],
      "bash_allow": [
        "flotilla status*",
        "git status*",
        "git diff*",
        "git log*",
        "git add*",
        "git commit*",
        "git push origin feat/*",
        "git push origin fix/*",
        "go test*",
        "go build*",
        "pytest*",
        "python -m pytest*"
      ],
      "bash_deny": [
        "flotilla notify*",
        "gh pr merge*",
        "git push origin main*",
        "git push origin master*",
        "git push --force*",
        "git reset --hard*"
      ],
      "elevation": {}
    },
    "transient-task-desk": {
      "extends": "desk",
      "capabilities": ["transient.scope"],
      "bash_allow": [],
      "bash_deny": [
        "git push*"
      ],
      "elevation": {}
    }
  },
  "materialization": {
    "gatekeeper_overlay_dir": "deploy/flotilla-permissions/overlays",
    "claude_permissions_dir": "deploy/flotilla-permissions/materialized/claude",
    "grok_allowlist_dir": "deploy/flotilla-permissions/materialized/grok",
    "codex_rules_dir": "deploy/flotilla-permissions/materialized/codex",
    "compiler": "scripts/compile-flotilla-permissions.sh",
    "sync": "flotilla bootstrap permissions sync",
    "design_criteria_consumer": {
      "compile_enforces": "policy.design_criteria",
      "doctor_check": "PERM_DESIGN_CRITERIA_DRIFT",
      "stamp_field": "design_criteria",
      "overlay_header_comment": true
    }
  }
}