# flotilla-watch host paths — consumed by deploy/flotilla-watch-install.sh to
# generate ~/.config/systemd/user/flotilla-watch.service from
# deploy/flotilla-watch.service.in.
#
# SETUP (one-time per host):
#   cp deploy/flotilla-watch.env.example deploy/flotilla-watch.env
#   $EDITOR deploy/flotilla-watch.env        # set the five paths for THIS host
#   bash deploy/flotilla-watch-install.sh    # generate + install the unit
#
# deploy/flotilla-watch.env is gitignored: these are filesystem paths (NOT secrets),
# but the layout is per-host, so each host keeps its own. To change paths later,
# edit this file and re-run the installer — never hand-edit the installed unit.
#
# Paths may use the systemd specifier %h (your home directory): the installer passes
# it through literally and systemd resolves it at runtime. Absolute paths also work.
# Values are taken LITERALLY — do NOT quote them (`KEY=%h/x`, not `KEY="%h/x"`);
# whitespace around the `=` is trimmed, but surrounding quotes are not stripped.

# Working directory for the daemon process. The clock and relay read their config by
# the absolute paths below, so this rarely matters functionally — set it to your repo
# or state root for tidy `systemctl --user status flotilla-watch` output.
FLOTILLA_WORKDIR=%h

# The flotilla binary. The `go install` default is %h/go/bin/flotilla.
FLOTILLA_BIN=%h/go/bin/flotilla

# Roster (committable, no secrets): agents, xo_agent, heartbeat_interval, and — for
# the relay — channel_id + operator_user_id.
FLOTILLA_ROSTER=%h/.config/flotilla/flotilla.json

# Secrets (chmod 600, never committed): FLOTILLA_BOT_TOKEN (relay) plus
# FLOTILLA_WEBHOOK_<AGENT> lines (audit mirror + alert/notice posts).
FLOTILLA_SECRETS=%h/.config/flotilla/flotilla-secrets.env

# XO liveness ack file the XO touches each tick. flotilla's built-in default is
# <roster-dir>/flotilla-xo-alive; set it explicitly here so the unit is self-describing.
FLOTILLA_ACK_FILE=%h/.config/flotilla/flotilla-xo-alive
